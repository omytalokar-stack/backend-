# Example backend environment variables
# Either set MONGODB_URI directly OR set MONGO_USER, MONGO_PASS, MONGO_HOST (optional) and MONGO_DB

# Full connection string (preferred)
# MONGODB_URI=mongodb+srv://user:password@cluster0.ia1xxxb.mongodb.net/mydbname?retryWrites=true&w=majority

# OR set components below:
MONGO_USER=omrtalokar146_db_user
MONGO_PASS=gameprincess
MONGO_HOST=cluster0.ia1xxxb.mongodb.net
MONGO_DB=your_db_name

# Comma separated list of frontend origins allowed by CORS (used in production)
# Example: https://your-frontend.vercel.app,https://another-origin.com
FRONTEND_URLS=http://localhost:3000,http://localhost:5173

# Backend URL (used for constructing upload URLs on Render)
# This should match your Render backend URL or production domain
BACKEND_URL=https://backend-d58c.onrender.com

# Backend URL (used for constructing upload URLs on Render)
BACKEND_URL=https://backend-d58c.onrender.com

# Port (Render will set this automatically)
PORT=5000

# Any other env vars (JWT secrets, API keys, etc.)
# JWT_SECRET=change_this_to_a_secure_value
